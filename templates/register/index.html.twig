{% extends 'base.html.twig'%}

{% block title %} {{ site_name }} : {{ 'register.titulo'|trans }} {% endblock %}

{% block body %}
<h1>{{ 'register.titulo'|trans }}</h1>
    <div class="registration--content flx-row">

    {{ form_start(register_form, {'attr': {'id': 'register-form'}}) }}
    {{ form_widget(register_form) }}
        <button type="submit" class="btn btn-primary">{{ 'register.boton'|trans }}</button>
    {{ form_end(register_form) }}

        {# Imagen de bienvenida de Habbo.es - hotel español #}
        <img src="https://www.habbo.es/habbo-web/spain/es/assets/images/teaser_registration.png"
             alt="{{ 'register.titulo'|trans }}"
             onerror="this.src='https://images.habbo.com/habbo-web/america/en/assets/images/teaser_registration.d401d183.png'">

    </div>
{% endblock %}
