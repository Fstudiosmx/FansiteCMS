{% extends 'base.html.twig' %}

{% block title %}{{ site_name }} : Registro{% endblock %}

{% block body %}
<h1>Registrarse</h1>

<div class="registration--content flx-row">

    {{ form_start(register_form, {'attr': {'id': 'register-form'}}) }}

    <div class="motto-notice">
        <i class="fi-rr-shield-check"></i>
        <p>
            Para verificar tu cuenta de <strong>Habbo.es</strong>, establece esta misión en tu personaje antes de registrarte:
        </p>
        <div class="motto-code">
            <code id="motto-token">{{ motto_token }}</code>
        </div>
        <small>Ve a Habbo.es → Perfil → Misión y pega el código de arriba. Luego vuelve aquí y completa el registro.</small>
    </div>

    {{ form_widget(register_form) }}

    <button type="submit" class="btn btn-primary">
        <i class="fi-rr-check"></i> Verificar y crear cuenta
    </button>

    {{ form_end(register_form) }}

    <div class="register-preview flx-column">
        <img src="https://www.habbo.es/habbo-imaging/avatarimage?user=Sulake&action=std&direction=2&head_direction=2&img_format=gif&gesture=std&size=l"
             id="avatar-preview" alt="Vista previa del avatar">
        <small>Vista previa de tu avatar de Habbo.es</small>
    </div>

</div>

<script>
    const usernameField = document.querySelector('input[name*="username"]');
    const preview = document.getElementById('avatar-preview');
    if (usernameField && preview) {
        usernameField.addEventListener('input', function () {
            const u = encodeURIComponent(this.value.trim());
            if (u.length > 2) {
                preview.src = 'https://www.habbo.es/habbo-imaging/avatarimage?user=' + u +
                    '&action=std&direction=2&head_direction=2&img_format=gif&gesture=std&size=l';
            }
        });
    }
</script>
{% endblock %}
