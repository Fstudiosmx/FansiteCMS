{% extends 'base.html.twig' %}

{% block title %}{{ site_name }} : {{ article.title|default('Artículos') }}{% endblock %}

{% block body %}
<div class="show-news-content w-100 flx-row">

    {% if article %}
        <div class="news-page--content w-100 flx-column">
            <div class="show-news w-100">
                <div class="article-thumbnail w-100" style="background-image: url('{{ article.ImaageUrL }}')"></div>
                <div class="article-content">
                    <h1>{{ article.title }}</h1>
                    <span>{{ article.content|raw }}</span>
                </div>
            </div>

            {% if app.user %}
                {% for message in app.flashes('success') %}
                    <div class="alert-success w-100">
                        <span>{{ message }} <a href="/noticias/{{ article.id }}">Actualizar</a></span>
                    </div>
                {% endfor %}
                <div class="comment-form flx-column w-100">
                    {{ form_start(comment_form) }}
                    {{ form_widget(comment_form) }}
                    <button type="submit" class="btn btn-primary">
                        <i class="fi-rr-comment"></i> Comentar
                    </button>
                    {{ form_end(comment_form) }}
                </div>
            {% endif %}

            {% for comment in comments|reverse %}
                <div class="comment-item flx-row w-100">
                    <img src="https://www.habbo.es/habbo-imaging/avatarimage?user={{ comment.author }}&action=std&direction=2&head_direction=2&img_format=gif&gesture=std&size=l"
                         alt="Autor del comentario" class="comments-author--avatar">
                    <div class="comment-item--details">
                        <h3>{{ comment.author }}</h3>
                        <span>{{ comment.content }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>

    {% else %}
        <div class="show-news w-100 show-news--error">
            <div class="article-content article-content--error">
                <img src="https://images.habbo.com/c_images/HabboWay/habboway_5a.png" alt="Error" />
                <h1>¡Ups!</h1>
                <span>El artículo que estás buscando no existe o fue eliminado.</span>
            </div>
        </div>
    {% endif %}

    <div class="list-other-news">
        {% for news in list %}
            <div class="listed-news w-100" style="background-image: url('{{ news.ImaageUrL }}');">
                <a href="/noticias/{{ news.id }}">
                    <div id="listed-news-title"><h4>{{ news.title }}</h4></div>
                </a>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
