{% extends "base.html.twig" %}

{% block title %}{{ site_name }} : {{ 'nav.inicio'|trans }}{% endblock %}

{%  block body %}

    <div class="page-info">
        <img src="https://images.habbo.com/c_images/HabboWay/habboway_2a.png" alt="Bienvenida">
        <div class="page-info--content">
            <h1>{{ 'nav.inicio'|trans }}</h1>
            <span>Bienvenido a nuestro sitio, aquí podrás descubrir la actualidad y los concursos organizados por nuestro equipo.</span>
        </div>
    </div>

    <h1>{{ 'news.actualidad'|trans }}</h1>

    <div class="index-news-list flx-row">

        <a href="/news/{{ lastarticle[0].id }}" id="last-news" style="background-image: url('{{ lastarticle[0].ImaageUrL }}')">
            <div class="last-article-content w-100">
                <div id="article-title">
                    <span id="article-title-text">{{ lastarticle[0].title }}</span>
                </div>
            </div>
        </a>

        <div class="other-news flx-column">
            <a href="/news/{{ lastarticle[1].id }}" class="a-news w-100" style="background-image: url('{{ lastarticle[1].ImaageUrL }}')">
                <div class="last-article-content w-100">
                    <div id="article-title">
                        <span id="article-title-text">{{ lastarticle[1].title }}</span>
                    </div>
                </div>
            </a>
            <a href="/news/{{ lastarticle[2].id }}" class="a-news w-100" style="background-image: url('{{ lastarticle[2].ImaageUrL }}')">
                <div class="last-article-content w-100">
                    <div id="article-title">
                        <span id="article-title-text">{{ lastarticle[2].title }}</span>
                    </div>
                </div>
            </a>
            <a href="/news/{{ lastarticle[3].id }}" class="a-news w-100" style="background-image: url('{{ lastarticle[3].ImaageUrL }}')">
                <div class="last-article-content w-100">
                    <div id="article-title">
                        <span id="article-title-text">{{ lastarticle[3].title }}</span>
                    </div>
                </div>
            </a>
        </div>

    </div>

    <div class="w-100" id="btn-see-more">
        <a href="/news">{{ 'news.ver_mas_noticias'|trans }} <i class="fi-rr-eye"></i></a>
    </div>

    <div class="index-two-columns flx-row">
        <div class="last-appartments">
            <h1>{{ 'room.ultimas'|trans }}</h1>

            {% for room in lastroom %}
                <div class="appartment flx-row w-100">
                    <div id="room-icon" style="background-image: url('{{ room.thumbnail }}')"></div>
                    <div id="room-desc">
                        <h2>{{ room.name }}</h2>
                        <span id="room-slug">{{ room.description }}</span>
                    </div>
                    <a href="#" class="gotoroom" title="{{ 'room.ir_a_habitacion'|trans }}">
                        <i class="fi-rr-angle-double-small-right"></i>
                    </a>
                </div>
            {% endfor %}

            <div id="btn-see-more">
                <a href="/room">{{ 'room.ver_todos'|trans }} <i class="fi-rr-eye"></i></a>
            </div>
        </div>

        <div class="last-forum-posts">
            <h1>{{ 'team.topics'|trans }}</h1>
            {% for post in forumPosts %}
                <div class="forum-post flx-row w-100">
                    {# Avatar del foro usando Habbo.es #}
                    <img src="https://www.habbo.es/habbo-imaging/avatarimage?user={{ post.author }}&headonly=0&direction=2&head_direction=2&size=l"
                         alt="Avatar de {{ post.author }}"
                         width="45" height="90"
                         loading="lazy"
                         onerror="this.src='https://www.habbo.es/habbo-imaging/avatarimage?user=default&size=l'">
                    <div class="forum-post-desc flx-column">
                        <h3>{{ post.title }}</h3>
                        <span>{{ post.description }}</span>
                        <span class="auteur">{{ post.author }}</span>
                    </div>
                    <a href="{{ post.forumlink }}" class="gotoroom" target="_blank" rel="noopener noreferrer">
                        <i class="fi-rr-angle-double-small-right"></i>
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>

    <h1>{{ 'flujo.titulo'|trans }}</h1>

    <div class="flux-city flx-row w-100">
        {% for data in staffStream %}
        <div class="box-flux flx-row">
            {# Avatar del flujo usando Habbo.es #}
            <img src="https://www.habbo.es/habbo-imaging/avatarimage?user={{ data.pseudo }}&headonly=0&direction=2&head_direction=2&size=l"
                 alt="Avatar de {{ data.pseudo }}"
                 width="45" height="90"
                 loading="lazy"
                 onerror="this.src='https://www.habbo.es/habbo-imaging/avatarimage?user=default&size=l'">
            <div class="box-flux--desc flx-column">
                <h2>{{ data.pseudo }}</h2>
                <span>{{ data.rank }}</span>
                <span>{{ data.date|date("d/m/Y") }}</span>
            </div>
            {% if data.type == 'QUIT' %}
                <i class="fi-rr-arrow-down arrow-down" title="{{ 'flujo.salida'|trans }}"></i>
            {% endif %}
            {% if data.type == 'ARRIVAL' %}
                <i class="fi-rr-arrow-up arrow-up" title="{{ 'flujo.llegada'|trans }}"></i>
            {% endif %}
            {% if data.type == 'SWITCH' %}
                <i class="fi-rr-rotate-right" title="{{ 'flujo.cambio'|trans }}"></i>
            {% endif %}
        </div>
        {% endfor %}
    </div>
{% endblock %}
