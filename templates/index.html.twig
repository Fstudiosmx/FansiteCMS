{% extends 'base.html.twig' %}

{% block title %}Inicio - {{ site_name }}{% endblock %}

{% block body %}
<div class="home-container">

    {# ---- BANNER PRINCIPAL ---- #}
    <div class="home-banner">
        <div class="banner-content">
            <h1 class="banner-title">¡Bienvenido a {{ site_name }}!</h1>
            <p class="banner-subtitle">El fansite oficial de Habbo Hotel en Español Latinoamérica</p>
            {% if not app.user %}
                <div class="banner-actions">
                    <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg">
                        🎮 {{ 'register.boton'|trans }}
                    </a>
                    <a href="{{ path('app_login') }}" class="btn btn-secondary btn-lg">
                        {{ 'auth.ingresar'|trans }}
                    </a>
                </div>
            {% else %}
                <p class="banner-welcome">{{ 'auth.bienvenido'|trans({'%nombre%': app.user.username}) }}</p>
            {% endif %}
            <a
                href="https://www.habbo.es"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-habbo-hotel"
            >
                🏨 Jugar en Habbo.es (Hotel Español)
            </a>
        </div>
    </div>

    {# ---- ÚLTIMAS NOTICIAS ---- #}
    <section class="home-section">
        <div class="section-header">
            <h2>{{ 'news.titulo'|trans }}</h2>
            <a href="{{ path('app_news') }}" class="ver-todas">{{ 'news.todas'|trans }} →</a>
        </div>

        {% if noticias is not empty %}
            <div class="news-grid">
            {% for noticia in noticias|slice(0, 6) %}
                <article class="news-card">
                    {% if noticia.imagenPortada %}
                        <img
                            src="{{ noticia.imagenPortada }}"
                            alt="{{ noticia.title }}"
                            loading="lazy"
                            class="news-card-image"
                        />
                    {% endif %}
                    <div class="news-card-body">
                        <h3 class="news-card-title">{{ noticia.title }}</h3>
                        <p class="news-card-meta">
                            {{ 'news.publicado_por'|trans }}
                            <strong>{{ noticia.author.username }}</strong>
                            {{ 'news.publicado_el'|trans }}
                            {{ noticia.publishedAt ? noticia.publishedAt|date('d/m/Y') : noticia.createdAt|date('d/m/Y') }}
                        </p>
                        {% if noticia.resumen %}
                            <p class="news-card-excerpt">{{ noticia.resumen }}</p>
                        {% endif %}
                        <a href="{{ path('app_news_show', {'slug': noticia.slug}) }}" class="btn btn-sm btn-outline">
                            {{ 'news.leer_mas'|trans }} →
                        </a>
                    </div>
                </article>
            {% endfor %}
            </div>
        {% else %}
            <p class="empty-state">{{ 'news.sin_noticias'|trans }}</p>
        {% endif %}
    </section>

    {# ---- HABITACIONES DESTACADAS ---- #}
    <section class="home-section">
        <div class="section-header">
            <h2>{{ 'room.titulo_plural'|trans }}</h2>
            <a href="{{ path('app_room') }}" class="ver-todas">Ver todas →</a>
        </div>

        {% if habitaciones is not empty %}
            <div class="rooms-grid">
            {% for habitacion in habitaciones|slice(0, 4) %}
                <div class="room-card">
                    <div class="room-card-body">
                        <h3>{{ habitacion.name }}</h3>
                        <p class="text-muted">{{ 'room.propietario'|trans }}: {{ habitacion.owner.username }}</p>
                        {% if habitacion.habboRoomId %}
                            <a
                                href="https://www.habbo.es/es/hotel?roomId={{ habitacion.habboRoomId }}"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn btn-sm btn-habbo"
                            >
                                🏠 {{ 'room.ver_en_habbo'|trans }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
            </div>
        {% else %}
            <p class="empty-state">{{ 'room.sin_habitaciones'|trans }}</p>
        {% endif %}
    </section>

</div>
{% endblock %}
