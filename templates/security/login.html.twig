{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.titulo_login'|trans }} - {{ site_name }}{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card">

        {# Logo / Cabecera #}
        <div class="auth-header">
            <img
                src="https://images.habbo.com/habbo-web-client/v4.2.2.4/desktop/icon.png"
                alt="Habbo Hotel"
                width="48"
                height="48"
                loading="lazy"
            />
            <h1>{{ 'auth.titulo_login'|trans }}</h1>
            <p class="auth-subtitle">{{ site_name }}</p>
        </div>

        {# Mensajes de error #}
        {% if error %}
            <div class="alert alert-error" role="alert">
                <span class="alert-icon">⚠️</span>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {# Mensaje de último nombre de usuario #}
        {% if last_username %}
            <div class="alert alert-info">
                Continuando como: <strong>{{ last_username }}</strong>
            </div>
        {% endif %}

        {# Formulario de inicio de sesión #}
        <form method="post" class="auth-form" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label for="inputEmail">{{ 'auth.correo'|trans }}</label>
                <input
                    type="email"
                    id="inputEmail"
                    name="email"
                    value="{{ last_username }}"
                    class="form-control"
                    autocomplete="email"
                    autofocus
                    placeholder="tu@correo.com"
                    required
                >
            </div>

            <div class="form-group">
                <label for="inputPassword">{{ 'auth.contrasena'|trans }}</label>
                <input
                    type="password"
                    id="inputPassword"
                    name="password"
                    class="form-control"
                    autocomplete="current-password"
                    placeholder="••••••••"
                    required
                >
            </div>

            <div class="form-check">
                <input type="checkbox" id="remember_me" name="_remember_me" class="form-check-input">
                <label for="remember_me" class="form-check-label">
                    {{ 'auth.recordarme'|trans }}
                </label>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                {{ 'auth.ingresar'|trans }}
            </button>
        </form>

        {# Enlace a registro #}
        <div class="auth-footer">
            <a href="{{ path('app_register') }}">
                {{ 'auth.no_tienes_cuenta'|trans }}
            </a>
        </div>

        {# Enlace al hotel habbo.es #}
        <div class="habbo-hotel-link">
            <a href="https://www.habbo.es" target="_blank" rel="noopener noreferrer">
                🏨 {{ 'habbo.hotel_espanol'|trans }}
            </a>
        </div>

    </div>
</div>
{% endblock %}
