{% extends 'base.html.twig' %}

{% block title %}{{ site_name }} : {{ 'auth.titulo_login'|trans }}{% endblock %}

{% block body %}
<form method="post">
    {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <h1 class="h3 mb-3 font-weight-normal">{{ 'auth.titulo_login'|trans }}</h1>

    <label for="inputUsername">{{ 'auth.nombre_usuario'|trans }}</label>
    <input type="text" value="{{ last_username }}" name="username" id="inputUsername" class="form-control" required autofocus>

    <label for="inputPassword">{{ 'auth.contrasena'|trans }}</label>
    <input type="password" name="password" id="inputPassword" class="form-control" required>

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    <div class="checkbox mb-3">
        <label>
            <input type="checkbox" name="_remember_me"> {{ 'auth.recordarme'|trans }}
        </label>
    </div>

    <button class="btn btn-lg btn-primary" type="submit">
        {{ 'auth.ingresar'|trans }}
    </button>

    <p class="mt-3">
        <a href="/register">{{ 'auth.no_tienes_cuenta'|trans }}</a>
    </p>
</form>
{% endblock %}
