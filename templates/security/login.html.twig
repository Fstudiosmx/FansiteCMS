{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.ingresar'|trans }}{% endblock %}

{% block body %}
<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="card-title h4 mb-4 text-center">
                    🔑 {{ 'auth.titulo'|trans }}
                </h1>

                {% if error %}
                    <div class="alert alert-danger">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}">
                    <div class="mb-3">
                        <label for="inputEmail" class="form-label fw-semibold">
                            {{ 'auth.correo'|trans }}
                        </label>
                        <input type="email"
                               id="inputEmail"
                               name="email"
                               class="form-control"
                               value="{{ last_username }}"
                               autocomplete="email"
                               required
                               autofocus>
                    </div>

                    <div class="mb-3">
                        <label for="inputPassword" class="form-label fw-semibold">
                            {{ 'auth.contrasena'|trans }}
                        </label>
                        <input type="password"
                               id="inputPassword"
                               name="password"
                               class="form-control"
                               autocomplete="current-password"
                               required>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me">
                        <label class="form-check-label" for="remember_me">
                            {{ 'auth.recordarme'|trans }}
                        </label>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            {{ 'auth.ingresar'|trans }}
                        </button>
                    </div>
                </form>

                <hr>
                <p class="text-center mb-0">
                    {{ 'auth.no_tienes_cuenta'|trans }}
                    <a href="{{ path('app_register') }}">{{ 'nav.registrarse'|trans }}</a>
                </p>
            </div>
        </div>

        <!-- Acceso directo al hotel español -->
        <div class="text-center mt-3">
            <a href="https://www.habbo.es" target="_blank" rel="noopener noreferrer" class="btn btn-warning btn-sm">
                🏨 {{ 'habbo.ir_al_hotel'|trans }}
            </a>
        </div>
    </div>
</div>
{% endblock %}
