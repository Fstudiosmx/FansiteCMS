{% extends 'base.html.twig' %}

{% block title %}{{ site_name }} : Iniciar sesión{% endblock %}

{% block body %}
<form method="post">
    {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <h1 class="h3 mb-3 font-weight-normal">Inicia sesión</h1>
    <label for="inputUsername">Nombre de usuario</label>
    <input type="text" value="{{ last_username }}" name="username" id="inputUsername" class="form-control" required autofocus>
    <label for="inputPassword">Contraseña</label>
    <input type="password" name="password" id="inputPassword" class="form-control" required>

    <input type="hidden" name="_csrf_token"
           value="{{ csrf_token('authenticate') }}"
    >

    {#
        Descomenta esta sección y agrega la opción remember_me en tu firewall para activar la función "Recordarme".
        Ver: https://symfony.com/doc/current/security/remember_me.html

        <div class="checkbox mb-3">
            <label>
                <input type="checkbox" name="_remember_me"> Recordarme
            </label>
        </div>
    #}

    <button class="btn btn-lg btn-primary" type="submit">
        Entrar
    </button>
</form>
{% endblock %}
