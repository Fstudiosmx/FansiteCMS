# En todos los entornos, los siguientes archivos se cargan si existen,
# siendo el último el que tiene precedencia sobre el anterior:
#
#  * .env                contiene los valores predeterminados para las variables de entorno
#  * .env.local          archivo no versionado con sobreescrituras locales
#  * .env.$APP_ENV       valores predeterminados específicos del entorno
#  * .env.$APP_ENV.local sobreescrituras específicas del entorno no versionadas
#
# Las variables de entorno reales tienen prioridad sobre los archivos .env.
#
# NO DEFINAS SECRETOS DE PRODUCCIÓN EN ESTE ARCHIVO NI EN NINGÚN ARCHIVO VERSIONADO.
#
# Ejecuta "composer dump-env prod" para compilar los archivos .env para producción.
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ab284dfffe36334d55fdc258ff3c8c0f
###< symfony/framework-bundle ###

###> symfony/mailer ###
# MAILER_DSN=smtp://localhost
###< symfony/mailer ###

###> doctrine/doctrine-bundle ###
# Formato descrito en: https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANTE: DEBES configurar la versión del servidor, ya sea aquí o en config/packages/doctrine.yaml
#
# SQLite (desarrollo local rápido):
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
#
# MySQL/MariaDB:
# DATABASE_URL="mysql://usuario:contraseña@127.0.0.1:3306/fansite?serverVersion=8.0"
#
# PostgreSQL (CONFIGURACIÓN ACTIVA):
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/fansite?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###

# Nombre del sitio (usado en templates)
SITE_NAME="FansiteCMS Habbo"

# Clave API del hotel Habbo
API_KEY="Cr53Rcgt67"

# Configuración regional
APP_LOCALE=es_419
APP_TIMEZONE=America/Mexico_City
